#!/bin/bash
source /etc/qubes-rpc/saltbridge.lib.sh

sb_require_vm_arg
sb_check_allowlist "$SB_VM"

read -r payload
cmd=$(printf '%s\n' "$payload" | python3 -c "import sys,json; print(json.load(sys.stdin)['cmd'])" 2>/dev/null)

if [[ -z "$cmd" ]]; then
    echo "ERROR: Invalid payload. Expected JSON with 'cmd' key." >&2
    exit 1
fi

qvm-run -p "$SB_VM" "$cmd" 2>&1
