## Salt Bridge — allow claude-vm to manage VMs via qrexec
## Replace CLAUDE_VM with the name of the VM running Claude Code

saltbridge.VmList      *  CLAUDE_VM  @adminvm  allow
saltbridge.VmStart     *  CLAUDE_VM  @adminvm  allow
saltbridge.VmShutdown  *  CLAUDE_VM  @adminvm  allow
saltbridge.VmNetworkInfo *  CLAUDE_VM  @adminvm  allow
saltbridge.VmExec      *  CLAUDE_VM  @adminvm  allow
saltbridge.VmExecRoot  *  CLAUDE_VM  @adminvm  allow
saltbridge.VmReadFile  *  CLAUDE_VM  @adminvm  allow
saltbridge.VmWriteFile *  CLAUDE_VM  @adminvm  allow
